# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-12109df04a8a4602b2a0a5f0536cb39f
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Model Parameters
# Temperature: 控制输出随机性，范围0.0-1.0，默认0.7
# 0.0: 更确定性的输出
# 1.0: 更创造性的输出
DEEPSEEK_TEMPERATURE=0.7

# Max Tokens: 最大输出令牌数，默认2000
DEEPSEEK_MAX_TOKENS=2000

# Stream: 是否使用流式输出，默认false
DEEPSEEK_STREAM=false

# Request Configuration
# Timeout: 请求超时时间(秒)，默认30.0
DEEPSEEK_TIMEOUT=30.0

# Max Retries: 最大重试次数，默认3
DEEPSEEK_MAX_RETRIES=3

# Retry Delay: 重试延迟时间(秒)，默认1.0
DEEPSEEK_RETRY_DELAY=1.0
